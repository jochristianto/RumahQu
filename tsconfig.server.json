{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist-server"
  },
  "include": ["server/src/**/*.ts", "server/scripts/**/*.ts", "server/tests/**/*.ts", "shared/**/*.ts"]
}
